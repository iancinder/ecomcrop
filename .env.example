# Copy this file to .env.local for local development, and paste these same
# keys into Vercel's Environment Variables for production. Fill in every value.

# Clerk — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Stripe — https://dashboard.stripe.com → Developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=

# Stripe Price IDs — create your two products, then copy each Price ID
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_LIFETIME=

# Stripe Webhook signing secret — from the webhook endpoint (or `stripe listen`)
STRIPE_WEBHOOK_SECRET=

# App base URL — used for Stripe success/cancel/return redirects
# Local: http://localhost:3000   Production: https://your-domain.vercel.app
NEXT_PUBLIC_URL=
